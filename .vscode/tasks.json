{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "ucx build FFNArena",
            "problemMatcher": []
        },
        {
            "label": "build&test",
            "type": "shell",
            "command": "ucx build TestFFNArena && ucx ucc TestFFNArena.TestFFNArena",
            "problemMatcher": []
        },
        {
            "label": "tdd",
            "type": "shell",
            "command": "npx nodemon --ext \"uc\" --exec \"ucx build FFNArena && ucx build TestFFNArena && ucx ucc TestFFNArena.TestFFNArena\"",
            "problemMatcher": []
        },
        {
            "label": "build & run server",
            "type": "shell",
            "command": "ucx build FFNArena && ucx ucc server DM-Fractal?Mutator=FFNArena.Profile8",
            "problemMatcher": []
        },
        {
            "label": "build & run server with dynamic profile",
            "type": "shell",
            "command": "ucx build FFNArena && ucx ucc server DM-Fractal?Mutator=FFNArena.FFNArena?ArenaProfile=Loaded",
            "problemMatcher": []
        },
        {
            "label": "join server",
            "type": "shell",
            "command": "ucx ut unreal://127.0.0.1:7777",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "close": true,
                "focus": false,
                "panel": "shared",
                "group": "joinGroup",
                "showReuseMessage": true,
                "clear": true
            }
        }
    ]
}