    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "cd ../System && del ArenaFFN.u && ucc make ini=..\\ArenaFFN\\project.ini",
            "problemMatcher": []
        },
        {
            "label": "build&test",
            "type": "shell",
            "command": "cd ../System && del ArenaFFN.u && ucc make ini=..\\ArenaFFN\\project.ini && ucc ArenaFFN.Test",
            "problemMatcher": []
        },
        {
            "label": "build & run server",
            "type": "shell",
            "command": "cd ../System && del ArenaFFN.u && ucc make ini=..\\ArenaFFN\\project.ini && ucc server dm-fractal?game=Botpack.DeathMatchPlus?mutator=ArenaFFN.ArenaFFNMutator",
            "problemMatcher": []
        },
        {
            "label": "build & run game",
            "type": "shell",
            "command": "cd ../System && del ArenaFFN.u && ucc make ini=..\\ArenaFFN\\project.ini && UnrealTournament dm-fractal?game=Botpack.DeathMatchPlus?mutator=ArenaFFN.ArenaFFNMutator",
            "problemMatcher": []
        }
    ]
}